{
  "title": "Nexus API - SRE Lite",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "title": "HTTP Error Rate (%)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "100 * sum(rate(nexus_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(nexus_http_requests_total[5m]))",
          "legendFormat": "error_rate"
        }
      ]
    },
    {
      "title": "HTTP Avg Latency by Path (ms)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (path) (rate(nexus_http_request_duration_ms_sum[5m])) / sum by (path) (rate(nexus_http_request_duration_ms_count[5m]))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "title": "Vault Timeout Rate (%)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "100 * sum(rate(nexus_vault_processing_total{error_category=\"timeout\"}[5m])) / sum(rate(nexus_vault_processing_total[5m]))",
          "legendFormat": "vault_timeout_rate"
        }
      ]
    },
    {
      "title": "Vault Processing Outcomes",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (result, document_family) (rate(nexus_vault_processing_total[5m]))",
          "legendFormat": "{{result}}/{{document_family}}"
        }
      ]
    },
    {
      "title": "Vault Inflight Jobs",
      "type": "stat",
      "targets": [
        {
          "expr": "nexus_vault_inflight",
          "legendFormat": "inflight"
        }
      ]
    }
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}
