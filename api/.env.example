APP_ENV=development
PORT=8080
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=vault-items
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
IDEMPOTENCY_CLEANUP_INTERVAL_SECONDS=0
IDEMPOTENCY_CLEANUP_BATCH_SIZE=500
CHILECOMPRA_BASE_URL=https://api.mercadopublico.cl
CHILECOMPRA_API_KEY=replace-with-chilecompra-api-key
CHILECOMPRA_TENDERS_PATH=/servicios/v1/publico/licitaciones.json
TENDER_SCORE_CACHE_TTL_SECONDS=900
ALERT_HTTP_ERROR_RATE_PERCENT=5
ALERT_VAULT_TIMEOUT_PERCENT=20
ALERT_VAULT_INFLIGHT_MAX=10
ALERT_WARMUP_SKIPPED_RATIO_PERCENT=30
